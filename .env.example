# MemeLearn Environment Variables

# Gemini API Key for meme caption generation
# Replace the value below with your actual API key from the Google AI Studio
# Get yours here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Port to run the Express backend on (Defaults to 5002)
PORT=5002

# MongoDB Connection String
MONGODB_URI=mongodb://127.0.0.1:27017/memelearn
